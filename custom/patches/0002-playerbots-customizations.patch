+
+            ItemTemplate const* itemTemplate = item->GetTemplate();
+            if (itemTemplate &&
+                (itemTemplate->Class == ITEM_CLASS_WEAPON || itemTemplate->Class == ITEM_CLASS_ARMOR))
+                player->DestroyItem(bag, slot, true);
