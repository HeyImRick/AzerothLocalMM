+
+bool RandomPlayerbotMgr::IsRegionalHost(Player* player) const
+{
+    return player && !regionalHostGuid.IsEmpty() && player->GetGUID() == regionalHostGuid;
+}
+
+bool RandomPlayerbotMgr::IsValidRegionalHostLocation(Player* player) const
+{
+    if (!player || !player->IsInWorld() || player->IsBeingTeleported() || !player->GetMap())
+        return false;
+
+    if (player->GetMap()->Instanceable() || player->InBattleground() || player->InArena())
+        return false;
+
+    // Unzoned coordinates include GM-only islands and invalid terrain.
+    return player->GetZoneId() != 0;
+}
+
+void RandomPlayerbotMgr::OnRegionalHostZoneChanged(Player* player, uint32 newZone, uint32 newArea)
+{
+    if (!sPlayerbotAIConfig.regionalPopulationEnabled || !IsRegionalHost(player) ||
+        !IsValidRegionalHostLocation(player))
+        return;
+
+    uint32 mapId = player->GetMapId();
+    uint32 now = NowSeconds();
+
+    if (!regionalZoneId)
+    {
+        regionalMapId = mapId;
+        regionalZoneId = newZone;
+        regionalAreaId = newArea;
+        regionalPendingMapId = 0;
+        regionalPendingZoneId = 0;
+        regionalPendingAreaId = 0;
+        regionalPendingSince = 0;
+        regionalLastRegionChange = now;
+        regionalForceRebalance = true;
+        RefreshRegionalNearbyZones(player);
+        return;
+    }
+
+    if (mapId == regionalMapId && newZone == regionalZoneId)
+    {
+        regionalAreaId = newArea;
+        return;
+    }
+
+    if (mapId != regionalPendingMapId || newZone != regionalPendingZoneId)
+    {
+        regionalPendingMapId = mapId;
+        regionalPendingZoneId = newZone;
+        regionalPendingAreaId = newArea;
+        regionalPendingSince = now;
+        LOG_DEBUG("playerbots", "Regional population pending region: map {} zone {}", mapId, newZone);
+    }
+}
+
+void RandomPlayerbotMgr::ClearRegionalPopulation()
+{
+    for (auto const& [botId, assignment] : regionalAssignments)
+    {
+        (void)assignment;
+        if (Player* bot = GetPlayerBot(ObjectGuid::Create<HighGuid::Player>(botId)))
+            if (PlayerbotAI* ai = GET_PLAYERBOT_AI(bot))
+                ai->rpgInfo.ChangeToIdle();
+    }
+
+    regionalAssignments.clear();
+    regionalNearbyZones.clear();
+    regionalHostGuid.Clear();
+    regionalMapId = 0;
+    regionalZoneId = 0;
+    regionalAreaId = 0;
+    regionalPendingMapId = 0;
+    regionalPendingZoneId = 0;
+    regionalPendingAreaId = 0;
+    regionalPendingSince = 0;
+    regionalLastRegionChange = 0;
+    regionalLastUpdate = 0;
+    regionalLastRebalance = 0;
+    regionalForceRebalance = false;
+    LOG_INFO("playerbots", "Regional population stopped; random bot behavior restored.");
+}
+
+bool RandomPlayerbotMgr::IsRegionalBotEligible(Player* bot)
+{
+    if (!bot || !bot->IsInWorld() || bot->IsBeingTeleported() || bot->IsInCombat() || bot->isDead() ||
+        bot->GetGroup() || bot->InBattleground() || bot->InArena() || bot->InBattlegroundQueue() ||
+        bot->HasUnitState(UNIT_STATE_IN_FLIGHT) || bot->HasUnitMovementFlag(MOVEMENTFLAG_ONTRANSPORT) ||
+        !bot->GetMap() || bot->GetMap()->Instanceable())
+        return false;
+
+    if (!IsRandomBot(bot) || bot->GetSession()->GetSecurity() > SEC_PLAYER)
+        return false;
+
+    PlayerbotAI* ai = GET_PLAYERBOT_AI(bot);
+    if (!ai || ai->HasPlayerNearby(sPlayerbotAIConfig.regionalPopulationRealPlayerProtectionRadius))
+        return false;
+
+    if (sPlayerbotAIConfig.regionalPopulationProtectQuestBots && !ai->GetCurrentIncompleteQuests().empty())
+        return false;
+
+    return true;
+}
+
+bool RandomPlayerbotMgr::IsRealPlayerNear(WorldLocation const& location, float range) const
+{
+    for (Player* player : players)
+    {
+        if (!player || !player->IsInWorld() || player->GetSession()->IsBot() ||
+            player->GetMapId() != location.GetMapId())
+            continue;
+
+        if (location.GetExactDist2d(player) < range)
+            return true;
+    }
+
+    return false;
+}
+
+void RandomPlayerbotMgr::RefreshRegionalNearbyZones(Player* host)
+{
+    regionalNearbyZones.clear();
+    if (!host)
+        return;
+
+    std::map<uint32, float> zoneDistances;
+    Map* map = sMapMgr->FindMap(regionalMapId, 0);
+    if (!map)
+        return;
+
+    for (WorldLocation const& loc : sTravelMgr.GetTeleportLocations(host))
+    {
+        if (loc.GetMapId() != regionalMapId)
+            continue;
+
+        uint32 zoneId = map->GetZoneId(host->GetPhaseMask(), loc.GetPositionX(), loc.GetPositionY(),
+                                      loc.GetPositionZ());
+        if (!zoneId || zoneId == regionalZoneId)
+            continue;
+
+        float distance = loc.GetExactDist2d(host);
+        auto itr = zoneDistances.find(zoneId);
+        if (itr == zoneDistances.end() || distance < itr->second)
+            zoneDistances[zoneId] = distance;
+    }
+
+    std::vector<std::pair<uint32, float>> sorted(zoneDistances.begin(), zoneDistances.end());
+    std::sort(sorted.begin(), sorted.end(),
+              [](auto const& left, auto const& right) { return left.second < right.second; });
+
+    for (auto const& [zoneId, distance] : sorted)
+    {
+        (void)distance;
+        regionalNearbyZones.push_back(zoneId);
+        if (regionalNearbyZones.size() >= sPlayerbotAIConfig.regionalPopulationNearbyZoneCount)
+            break;
+    }
+}
+
+bool RandomPlayerbotMgr::BuildRegionalDestination(Player* bot, RegionalCategory category,
+                                                   WorldLocation& destination, uint32& zoneId, uint32& areaId)
+{
+    Player* host = ObjectAccessor::FindPlayer(regionalHostGuid);
+    if (!host || !IsValidRegionalHostLocation(host))
+        return false;
+
+    Map* map = sMapMgr->FindMap(regionalMapId, 0);
+    if (!map)
+        return false;
+
+    std::vector<WorldLocation> candidates;
+    for (WorldLocation const& loc : sTravelMgr.GetTeleportLocations(bot))
+    {
+        if (loc.GetMapId() != regionalMapId)
+            continue;
+
+        uint32 candidateZone = map->GetZoneId(bot->GetPhaseMask(), loc.GetPositionX(), loc.GetPositionY(),
+                                              loc.GetPositionZ());
+        uint32 candidateArea = map->GetAreaId(bot->GetPhaseMask(), loc.GetPositionX(), loc.GetPositionY(),
+                                              loc.GetPositionZ());
+        if (!candidateZone || !candidateArea)
+            continue;
+
+        bool correctZone = category == RegionalCategory::HostZone
+                               ? candidateZone == regionalZoneId
+                               : std::find(regionalNearbyZones.begin(), regionalNearbyZones.end(), candidateZone) !=
+                                     regionalNearbyZones.end();
+        if (!correctZone)
+            continue;
+
+        auto bracket = sPlayerbotAIConfig.zoneBrackets.find(candidateZone);
+        if (bracket != sPlayerbotAIConfig.zoneBrackets.end())
+        {
+            uint32 minLevel = bracket->second.first > sPlayerbotAIConfig.regionalPopulationZoneLevelLowerMargin
+                                  ? bracket->second.first -
+                                        sPlayerbotAIConfig.regionalPopulationZoneLevelLowerMargin
+                                  : 1;
+            uint32 maxLevel = std::min<uint32>(
+                sWorld->getIntConfig(CONFIG_MAX_PLAYER_LEVEL),
+                bracket->second.second + sPlayerbotAIConfig.regionalPopulationZoneLevelUpperMargin);
+            if (bot->GetLevel() < minLevel || bot->GetLevel() > maxLevel)
+                continue;
+        }
+
+        float hostDistance = loc.GetExactDist2d(host);
+        if (category == RegionalCategory::HostZone &&
+            (hostDistance < sPlayerbotAIConfig.regionalPopulationMinDistanceFromHost ||
+             hostDistance > sPlayerbotAIConfig.regionalPopulationMaxDistanceInHostZone))
+            continue;
+
+        if (IsRealPlayerNear(loc, sPlayerbotAIConfig.regionalPopulationRealPlayerProtectionRadius))
+            continue;
+
+        uint32 zonePopulation = 0;
+        uint32 areaPopulation = 0;
+        uint32 pointPopulation = 0;
+        for (auto const& [guid, onlineBot] : playerBots)
+        {
+            (void)guid;
+            if (!onlineBot || !onlineBot->IsInWorld() || onlineBot->GetMapId() != loc.GetMapId())
+                continue;
+            if (onlineBot->GetZoneId() == candidateZone)
+                ++zonePopulation;
+            if (onlineBot->GetAreaId() == candidateArea)
+                ++areaPopulation;
+            if (loc.GetExactDist2d(onlineBot) <
+                sPlayerbotAIConfig.regionalPopulationMinDistanceBetweenDestinations)
+                ++pointPopulation;
+        }
+
+        for (auto const& [assignedBotId, assignment] : regionalAssignments)
+        {
+            (void)assignedBotId;
+            if (assignment.zoneId == candidateZone)
+                ++zonePopulation;
+            if (assignment.areaId == candidateArea)
+                ++areaPopulation;
+            if (assignment.destination.GetMapId() == loc.GetMapId() &&
+                assignment.destination.GetExactDist2d(loc) <
+                    sPlayerbotAIConfig.regionalPopulationMinDistanceBetweenDestinations)
+                ++pointPopulation;
+        }
+
+        if (zonePopulation >= sPlayerbotAIConfig.regionalPopulationMaxPerZone ||
+            areaPopulation >= sPlayerbotAIConfig.regionalPopulationMaxPerSubArea ||
+            pointPopulation >= sPlayerbotAIConfig.regionalPopulationMaxPerPoint)
+            continue;
+
+        candidates.push_back(loc);
+    }
+
+    if (candidates.empty())
+        return false;
+
+    std::shuffle(candidates.begin(), candidates.end(), RandomEngine::Instance());
+    destination = candidates.front();
+    zoneId = map->GetZoneId(bot->GetPhaseMask(), destination.GetPositionX(), destination.GetPositionY(),
+                            destination.GetPositionZ());
+    areaId = map->GetAreaId(bot->GetPhaseMask(), destination.GetPositionX(), destination.GetPositionY(),
+                            destination.GetPositionZ());
+    return true;
+}
+
+bool RandomPlayerbotMgr::ProcessRegionalAssignment(Player* bot, RegionalAssignment& assignment)
+{
+    if (!bot || !bot->IsInWorld())
+        return false;
+
+    if (bot->GetMapId() == assignment.destination.GetMapId() &&
+        bot->GetZoneId() == assignment.zoneId &&
+        bot->GetExactDist2d(assignment.destination) <= 150.0f)
+        return false;
+
+    if (!IsRegionalBotEligible(bot))
+        return true;
+
+    uint32 now = NowSeconds();
+    if (!assignment.organicStarted && sPlayerbotAIConfig.regionalPopulationOrganicTravel &&
+        bot->GetMapId() == assignment.destination.GetMapId() &&
+        bot->GetExactDist2d(assignment.destination) <=
+            sPlayerbotAIConfig.regionalPopulationMaxWalkingRouteDistance)
+    {
+        if (PlayerbotAI* ai = GET_PLAYERBOT_AI(bot))
+        {
+            ai->rpgInfo.ChangeToGoGrind(WorldPosition(assignment.destination));
+            assignment.organicStarted = true;
+            assignment.lastAttemptAt = now;
+            LOG_DEBUG("playerbots", "Regional population: {} walking to zone {}", bot->GetName(),
+                      assignment.zoneId);
+            return true;
+        }
+    }
+
+    if (sPlayerbotAIConfig.regionalPopulationAllowSilentFallback &&
+        now >= assignment.assignedAt + sPlayerbotAIConfig.regionalPopulationSilentFallbackAfter &&
+        !IsRealPlayerNear(assignment.destination,
+                          sPlayerbotAIConfig.regionalPopulationRealPlayerProtectionRadius) &&
+        !GET_PLAYERBOT_AI(bot)->HasPlayerNearby(
+            sPlayerbotAIConfig.regionalPopulationRealPlayerProtectionRadius))
+    {
+        bot->GetMotionMaster()->Clear();
+        GET_PLAYERBOT_AI(bot)->Reset(true);
+        bot->RemoveAurasWithInterruptFlags(AURA_INTERRUPT_FLAG_TELEPORTED | AURA_INTERRUPT_FLAG_CHANGE_MAP);
+        bot->TeleportTo(assignment.destination);
+        assignment.lastAttemptAt = now;
+        LOG_DEBUG("playerbots", "Regional population: {} silently moved to zone {}", bot->GetName(),
+                  assignment.zoneId);
+    }
+
+    return true;
+}
+
+bool RandomPlayerbotMgr::StartRegionalAssignment(Player* bot, RegionalCategory category)
+{
+    WorldLocation destination;
+    uint32 zoneId = 0;
+    uint32 areaId = 0;
+    if (!BuildRegionalDestination(bot, category, destination, zoneId, areaId))
+        return false;
+
+    RegionalAssignment assignment;
+    assignment.category = category;
+    assignment.destination = destination;
+    assignment.zoneId = zoneId;
+    assignment.areaId = areaId;
+    assignment.assignedAt = NowSeconds();
+    regionalAssignments[bot->GetGUID().GetCounter()] = assignment;
+    regionalBotCooldowns[bot->GetGUID().GetCounter()] =
+        assignment.assignedAt + sPlayerbotAIConfig.regionalPopulationBotReassignmentCooldown;
+    ProcessRegionalAssignment(bot, regionalAssignments[bot->GetGUID().GetCounter()]);
+    return true;
+}
+
+void RandomPlayerbotMgr::UpdateRegionalPopulation()
+{
+    if (!sPlayerbotAIConfig.regionalPopulationEnabled || regionalPaused || regionalHostGuid.IsEmpty())
+        return;
+
+    uint32 now = NowSeconds();
+    if (regionalLastUpdate &&
+        now < regionalLastUpdate + sPlayerbotAIConfig.regionalPopulationUpdateInterval)
+        return;
+    regionalLastUpdate = now;
+
+    Player* host = ObjectAccessor::FindPlayer(regionalHostGuid);
+    if (!host || !host->IsInWorld() || host->GetSession()->GetAccountId() !=
+                                           sPlayerbotAIConfig.regionalPopulationHostAccountId)
+    {
+        ClearRegionalPopulation();
+        return;
+    }
+
+    if (regionalPendingZoneId &&
+        now >= regionalPendingSince + sPlayerbotAIConfig.regionalPopulationZoneStableTime &&
+        now >= regionalLastRegionChange + sPlayerbotAIConfig.regionalPopulationRegionChangeCooldown)
+    {
+        regionalMapId = regionalPendingMapId;
+        regionalZoneId = regionalPendingZoneId;
+        regionalAreaId = regionalPendingAreaId;
+        regionalPendingMapId = 0;
+        regionalPendingZoneId = 0;
+        regionalPendingAreaId = 0;
+        regionalPendingSince = 0;
+        regionalLastRegionChange = now;
+        regionalForceRebalance = true;
+        RefreshRegionalNearbyZones(host);
+        LOG_INFO("playerbots", "Regional population moved to map {} zone {}", regionalMapId, regionalZoneId);
+    }
+
+    for (auto itr = regionalAssignments.begin(); itr != regionalAssignments.end();)
+    {
+        Player* bot = GetPlayerBot(ObjectGuid::Create<HighGuid::Player>(itr->first));
+        if (!bot || !ProcessRegionalAssignment(bot, itr->second))
+            itr = regionalAssignments.erase(itr);
+        else
+            ++itr;
+    }
+
+    if (!regionalForceRebalance && regionalLastRebalance &&
+        now < regionalLastRebalance + sPlayerbotAIConfig.regionalPopulationRebalanceInterval)
+        return;
+
+    regionalLastRebalance = now;
+    regionalForceRebalance = false;
+
+    uint32 onlineBots = playerBots.size();
+    uint32 targetHost = onlineBots * sPlayerbotAIConfig.regionalPopulationHostZonePercent / 100;
+    uint32 targetNearby = onlineBots * sPlayerbotAIConfig.regionalPopulationNearbyZonesPercent / 100;
+    uint32 hostCount = 0;
+    uint32 nearbyCount = 0;
+    uint32 sameFactionCount = 0;
+    TeamId hostTeam = host->GetTeamId();
+    for (auto const& [guid, bot] : playerBots)
+    {
+        (void)guid;
+        if (!bot || !bot->IsInWorld() || bot->GetMapId() != regionalMapId)
+            continue;
+        if (bot->GetZoneId() == regionalZoneId)
+        {
+            ++hostCount;
+            if (bot->GetTeamId() == hostTeam)
+                ++sameFactionCount;
+        }
+        else if (std::find(regionalNearbyZones.begin(), regionalNearbyZones.end(), bot->GetZoneId()) !=
+                 regionalNearbyZones.end())
+        {
+            ++nearbyCount;
+            if (bot->GetTeamId() == hostTeam)
+                ++sameFactionCount;
+        }
+    }
+
+    for (auto const& [botId, assignment] : regionalAssignments)
+    {
+        Player* bot = GetPlayerBot(ObjectGuid::Create<HighGuid::Player>(botId));
+        if (!bot || (bot->GetMapId() == regionalMapId && bot->GetZoneId() == assignment.zoneId))
+            continue;
+        if (assignment.category == RegionalCategory::HostZone)
+            ++hostCount;
+        else
+            ++nearbyCount;
+        if (bot->GetTeamId() == hostTeam)
+            ++sameFactionCount;
     }
+
+    uint32 starts = 0;
+    uint32 traveling = regionalAssignments.size();
+    std::vector<Player*> candidates;
+    for (auto const& [guid, bot] : playerBots)
+    {
+        uint32 botId = guid.GetCounter();
+        if (!IsRegionalBotEligible(bot) || regionalAssignments.contains(botId) ||
+            (regionalBotCooldowns.contains(botId) && regionalBotCooldowns[botId] > now))
+            continue;
+        candidates.push_back(bot);
+    }
+
+    std::shuffle(candidates.begin(), candidates.end(), RandomEngine::Instance());
+    uint32 regionalTarget = targetHost + targetNearby;
+    uint32 sameFactionTarget =
+        (regionalTarget * sPlayerbotAIConfig.regionalPopulationSameFactionPercent + 99) / 100;
+    bool preferSameFaction = sameFactionCount < sameFactionTarget;
+    std::stable_sort(candidates.begin(), candidates.end(), [hostTeam, preferSameFaction](Player* left, Player* right)
+    {
+        bool leftPreferred = (left->GetTeamId() == hostTeam) == preferSameFaction;
+        bool rightPreferred = (right->GetTeamId() == hostTeam) == preferSameFaction;
+        return leftPreferred > rightPreferred;
+    });
+
+    for (Player* bot : candidates)
+    {
+        if (starts >= sPlayerbotAIConfig.regionalPopulationMaxTravelStartsPerCycle ||
+            traveling >= sPlayerbotAIConfig.regionalPopulationMaxTravelingBots)
+            break;
+
+        RegionalCategory category;
+        if (hostCount < targetHost)
+            category = RegionalCategory::HostZone;
+        else if (nearbyCount < targetNearby)
+            category = RegionalCategory::NearbyZone;
+        else
+            break;
+
+        if (!StartRegionalAssignment(bot, category))
+            continue;
+
+        ++starts;
+        ++traveling;
+        if (category == RegionalCategory::HostZone)
+            ++hostCount;
+        else
+            ++nearbyCount;
+        if (bot->GetTeamId() == hostTeam)
+            ++sameFactionCount;
+    }
+}
+
+std::string RandomPlayerbotMgr::GetRegionalPopulationStatus() const
+{
+    std::ostringstream out;
+    out << "Regional population: "
+        << (!sPlayerbotAIConfig.regionalPopulationEnabled ? "disabled" : regionalPaused ? "paused" : "enabled");
+    if (regionalHostGuid.IsEmpty())
+        return out.str() + ", no host online";
+
+    Player* host = ObjectAccessor::FindPlayer(regionalHostGuid);
+    uint32 hostCount = 0;
+    uint32 nearbyCount = 0;
+    for (auto const& [guid, bot] : playerBots)
+    {
+        (void)guid;
+        if (!bot || !bot->IsInWorld() || bot->GetMapId() != regionalMapId)
+            continue;
+        if (bot->GetZoneId() == regionalZoneId)
+            ++hostCount;
+        else if (std::find(regionalNearbyZones.begin(), regionalNearbyZones.end(), bot->GetZoneId()) !=
+                 regionalNearbyZones.end())
+            ++nearbyCount;
+    }
+
+    uint32 onlineBots = playerBots.size();
+    uint32 targetHost = onlineBots * sPlayerbotAIConfig.regionalPopulationHostZonePercent / 100;
+    uint32 targetNearby = onlineBots * sPlayerbotAIConfig.regionalPopulationNearbyZonesPercent / 100;
+    out << ", host=" << (host ? host->GetName() : "offline")
+        << ", map=" << regionalMapId << ", zone=" << regionalZoneId
+        << ", nearbyZones=" << regionalNearbyZones.size()
+        << ", hostZone=" << hostCount << "/" << targetHost
+        << ", nearby=" << nearbyCount << "/" << targetNearby
+        << ", world=" << (onlineBots - std::min(onlineBots, hostCount + nearbyCount))
+        << ", traveling=" << regionalAssignments.size();
+    return out.str();
+}
+
+bool RandomPlayerbotMgr::HandleRegionalPopulationCommand(ChatHandler* handler, std::string const& args)
+{
+    std::string command = args;
+    std::transform(command.begin(), command.end(), command.begin(),
+                   [](unsigned char c) { return static_cast<char>(std::tolower(c)); });
+
+    if (command.empty() || command == "status")
+    {
+        handler->SendSysMessage(GetRegionalPopulationStatus());
+        return true;
+    }
+    if (command == "pause")
+    {
+        regionalPaused = true;
+        handler->SendSysMessage("Regional population paused.");
+        return true;
+    }
+    if (command == "resume")
+    {
+        regionalPaused = false;
+        regionalForceRebalance = true;
+        handler->SendSysMessage("Regional population resumed.");
+        return true;
+    }
+    if (command == "rebalance")
+    {
+        regionalForceRebalance = true;
+        regionalLastRebalance = 0;
+        handler->SendSysMessage("Regional population rebalance scheduled.");
+        return true;
+    }
+    if (command == "clear")
+    {
+        ClearRegionalPopulation();
+        handler->SendSysMessage("Regional population state cleared.");
+        return true;
+    }
+
+    handler->SendSysMessage("Usage: .playerbots region [status|pause|resume|rebalance|clear]");
+    return false;
 }
 
