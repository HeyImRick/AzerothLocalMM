+    static bool EquipPeakItem(Player* player, uint8 slot, uint32 itemId)
+    {
+        ItemTemplate const* itemTemplate = sObjectMgr->GetItemTemplate(itemId);
+        if (!itemTemplate)
+            return false;
+
+        if (itemTemplate->RequiredReputationFaction && itemTemplate->RequiredReputationRank > 0)
+            if (FactionEntry const* factionEntry =
+                    sFactionStore.LookupEntry(itemTemplate->RequiredReputationFaction))
+            {
+                ReputationRank requiredRank =
+                    static_cast<ReputationRank>(itemTemplate->RequiredReputationRank);
+                if (player->GetReputationRank(itemTemplate->RequiredReputationFaction) < requiredRank)
+                {
+                    int32 standing =
+                        ReputationMgr::ReputationRankToStanding(
+                            static_cast<ReputationRank>(requiredRank - 1)) + 1;
+                    player->GetReputationMgr().SetReputation(factionEntry, standing);
+                }
+            }
+
+        if (player->CanUseItem(itemTemplate) != EQUIP_ERR_OK)
+            return false;
+
+        uint32 previousItemId = 0;
+        if (Item* previousItem = player->GetItemByPos(INVENTORY_SLOT_BAG_0, slot))
+            previousItemId = previousItem->GetEntry();
+
+        uint32 previousOffhandId = 0;
+        bool clearOffhand = slot == EQUIPMENT_SLOT_MAINHAND &&
+                            itemTemplate->InventoryType == INVTYPE_2HWEAPON;
+        if (clearOffhand)
+            if (Item* offhand = player->GetItemByPos(INVENTORY_SLOT_BAG_0, EQUIPMENT_SLOT_OFFHAND))
+            {
+                previousOffhandId = offhand->GetEntry();
+                player->DestroyItem(INVENTORY_SLOT_BAG_0, EQUIPMENT_SLOT_OFFHAND, true);
+            }
+
+        if (player->GetItemByPos(INVENTORY_SLOT_BAG_0, slot))
+            player->DestroyItem(INVENTORY_SLOT_BAG_0, slot, true);
+
+        uint16 destination = 0;
+        InventoryResult result = player->CanEquipNewItem(slot, destination, itemId, false);
+        if (result != EQUIP_ERR_OK && slot == EQUIPMENT_SLOT_MAINHAND && !clearOffhand)
+        {
+            if (Item* offhand = player->GetItemByPos(INVENTORY_SLOT_BAG_0, EQUIPMENT_SLOT_OFFHAND))
+            {
+                previousOffhandId = offhand->GetEntry();
+                player->DestroyItem(INVENTORY_SLOT_BAG_0, EQUIPMENT_SLOT_OFFHAND, true);
+            }
+            result = player->CanEquipNewItem(slot, destination, itemId, false);
+        }
+
+        if (result == EQUIP_ERR_OK)
+        {
+            player->EquipNewItem(destination, itemId, true);
+            player->AutoUnequipOffhandIfNeed();
+            return true;
+        }
+
+        if (previousItemId)
+        {
+            uint16 fallbackDestination = 0;
+            if (player->CanEquipNewItem(slot, fallbackDestination, previousItemId, false) == EQUIP_ERR_OK)
+                player->EquipNewItem(fallbackDestination, previousItemId, true);
+        }
+
+        if (previousOffhandId &&
+            !player->GetItemByPos(INVENTORY_SLOT_BAG_0, EQUIPMENT_SLOT_OFFHAND))
+        {
+            uint16 fallbackDestination = 0;
+            if (player->CanEquipNewItem(
+                    EQUIPMENT_SLOT_OFFHAND, fallbackDestination, previousOffhandId, false) == EQUIP_ERR_OK)
+                player->EquipNewItem(fallbackDestination, previousOffhandId, true);
+        }
+
+        return false;
+    }
+
+    static uint32 ApplyPeakGear(Player* player, uint8 specTab)
+    {
+        constexpr uint16 PeakGearLevel = 290;
+        constexpr uint16 FallbackWindow = 100;
+
+        uint8 faction = player->GetTeamId() == TEAM_ALLIANCE ? 1 : 2;
+        uint16 resolvedLevel = 0;
+        std::map<uint8, uint32> bisItems =
+            sBisListMgr->GetBisForNearest(PeakGearLevel, FallbackWindow, player->getClass(), specTab, faction,
+                                          &resolvedLevel);
+
+        DestroyPeakGear(player);
+
+        uint32 gearScoreLimit = PlayerbotFactory::CalcMixedGearScore(PeakGearLevel, ITEM_QUALITY_EPIC);
+        PlayerbotFactory fillFactory(player, player->GetLevel(), ITEM_QUALITY_EPIC, gearScoreLimit);
+        fillFactory.InitEquipment(false, true);
+
+        std::set<uint32> bisEntries;
+        for (auto const& [slot, itemId] : bisItems)
+        {
+            (void)slot;
+            bisEntries.insert(itemId);
+        }
+
+        for (uint8 slot = EQUIPMENT_SLOT_START; slot < EQUIPMENT_SLOT_END; ++slot)
+            if (Item* item = player->GetItemByPos(INVENTORY_SLOT_BAG_0, slot))
+                if (bisEntries.contains(item->GetEntry()))
+                    player->DestroyItem(INVENTORY_SLOT_BAG_0, slot, true);
+
+        constexpr std::array<uint8, 3> WeaponSlots = {
+            EQUIPMENT_SLOT_MAINHAND, EQUIPMENT_SLOT_OFFHAND, EQUIPMENT_SLOT_RANGED};
+        for (uint8 slot : WeaponSlots)
+        {
+            auto item = bisItems.find(slot);
+            if (item == bisItems.end())
+                continue;
+
+            uint32 itemId = item->second;
+            EquipPeakItem(player, slot, itemId);
+        }
+
+        for (auto const& [slot, itemId] : bisItems)
+        {
+            if (std::find(WeaponSlots.begin(), WeaponSlots.end(), slot) != WeaponSlots.end())
+                continue;
+
+            uint8 pairedSlot = 0xFF;
+            if (slot == EQUIPMENT_SLOT_FINGER1) pairedSlot = EQUIPMENT_SLOT_FINGER2;
+            else if (slot == EQUIPMENT_SLOT_FINGER2) pairedSlot = EQUIPMENT_SLOT_FINGER1;
+            else if (slot == EQUIPMENT_SLOT_TRINKET1) pairedSlot = EQUIPMENT_SLOT_TRINKET2;
+            else if (slot == EQUIPMENT_SLOT_TRINKET2) pairedSlot = EQUIPMENT_SLOT_TRINKET1;
+
